#!/usr/bin/make -f
# -*- mode: makefile; coding: utf-8 -*-

#DEB_MAKE_CHECK_TARGET = test_bitcoin
#build/bitcoind::
#	$(if $(filter nocheck,$(DEB_BUILD_OPTIONS)),,src/test_bitcoin)

DEB_INSTALL_EXAMPLES_innovad += debian/examples/*
DEB_INSTALL_MANPAGES_innovad += debian/manpages/*

%:
	dh --with bash-completion $@

override_dh_auto_build:
	cd src; $(MAKE) -f makefile.unix innovad
	$(MAKE)

override_dh_auto_clean:
	if [ -f Makefile ]; then $(MAKE) clean; else rm -rf build/; rm -f innova-qt; fi
	cd src; $(MAKE) -f makefile.unix clean

override_dh_auto_configure:
	qmake innova-qt.pro USE_QRCODE=1 USE_NATIVETOR=-

override_dh_auto_test:
	cd src; $(MAKE) -f makefile.unix test_innova
	src/test_innova

# Ensure wrapper is set executable
binary-post-install/innovad:
	chmod +x $(cdbs_curdestdir)usr/bin/innovad
binary-post-install/innova-qt:
	chmod +x $(cdbs_curdestdir)usr/bin/innova-qt
